<simulation verbosity="high">
  <output prefix="NPT">
      
    <properties filename="out" stride="200">  [ step, time{picosecond}, conserved{electronvolt}, temperature{kelvin}, kinetic_md{electronvolt}, potential{electronvolt}, pressure_md{gigapascal}, volume{angstrom3}, cell_h{angstrom} ] </properties>
    <trajectory filename="pos" stride="1000" format="ase"> positions </trajectory>
    <checkpoint filename="checkpoint" stride="5000" overwrite="True"> </checkpoint>
  </output>
  <total_steps>400000</total_steps>
  <prng>
    <seed>31415</seed>
  </prng>
  <ffsocket name="driver" mode="unix" pbc="False">
      <address>ipi_driver_118283_1745318106</address>
  </ffsocket>
  <system>
    <initialize nbeads="1">
      <file mode="chk"> RESTART </file>
    </initialize>
    <forces>
      <force forcefield="driver"> </force>
    </forces>
    <motion mode="dynamics">
      <dynamics mode="npt">
	 
         <barostat mode="flexible">
           <tau units="femtosecond"> 100 </tau>
           <thermostat mode="langevin"> 
	     <tau units="femtosecond"> 100 </tau> 
	   </thermostat>
         </barostat>
	  
         <thermostat mode="langevin"> 
	   <tau units="femtosecond"> 100 </tau> 
	 </thermostat>
         
        <timestep units="femtosecond">0.5</timestep>
      </dynamics>
    </motion>
    <ensemble>
      <temperature units="kelvin">300</temperature>
      <pressure units="bar"> 1.0 </pressure>
    </ensemble>
  </system>
</simulation>